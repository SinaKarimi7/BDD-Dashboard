# GitHub OAuth Configuration
# Create a GitHub OAuth App at https://github.com/settings/developers
# Set the Authorization callback URL to: https://your-domain.vercel.app/api/github/callback

# GitHub OAuth App Client ID (public, safe to expose)
VITE_GITHUB_CLIENT_ID=your_github_client_id_here

# GitHub OAuth App Client Secret (private, server-side only)
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# GitHub OAuth App Client ID (server-side reference)
GITHUB_CLIENT_ID=your_github_client_id_here
